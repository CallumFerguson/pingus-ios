{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-vs2022",
      "displayName": "Windows - Visual Studio 2022 (x64)",
      "description": "MSVC x64. Requires VCPKG_ROOT env var and scripts/setup-deps.ps1 to be run first.",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-vs2022",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "${sourceDir}/deps",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "WARNINGS": "OFF",
        "BUILD_TESTS": "OFF",
        "BUILD_EXTRA": "OFF"
      }
    },
    {
      "name": "windows-mingw",
      "displayName": "Windows - MinGW-w64 / MSYS2 (x64)",
      "description": "MinGW-w64 x64. Requires VCPKG_ROOT env var and scripts/setup-deps.ps1 -Triplet x64-mingw-dynamic to be run first.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-mingw",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_PREFIX_PATH": "${sourceDir}/deps",
        "VCPKG_TARGET_TRIPLET": "x64-mingw-dynamic",
        "WARNINGS": "OFF",
        "BUILD_TESTS": "OFF",
        "BUILD_EXTRA": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-vs2022-release",
      "displayName": "Windows VS2022 Release",
      "configurePreset": "windows-vs2022",
      "configuration": "Release"
    },
    {
      "name": "windows-mingw-release",
      "displayName": "Windows MinGW Release",
      "configurePreset": "windows-mingw"
    }
  ]
}
